	"description": "Geometry Dash but really hardcore.",
	"dependencies": {
		"geode.node-ids": ">=v1.20.0"
	},
	"tags": ["gameplay", "offline", "enhancement"],
	"links": {
		"source": "https://github.com/Tyegurr/HardcoreGD"
	},
	"resources": {
