		"lives": {
			"name": "Lives",
			"type": "int",
			"min": 1,
			"max": 16,
			"default": 4,
			"description": "You must like reading."
		},
		"always-hardcore": {
			"name": "Always Hardcore",
			"type": "bool",
			"default": false,
			"description": "Disable the annoying difficulty prompt and assume hardcore always."
		}
	}
